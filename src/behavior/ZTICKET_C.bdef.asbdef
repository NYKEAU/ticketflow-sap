projection;
strict ( 2 );

define behavior for ZTICKET_C alias Ticket
  use etag
{
  use create;
  use update;
  use delete;

  use determination setTimestamps;
  use determination setUpdateTimestamp;

  use validation validateStatus;
  use validation checkClosingComment;

  use action assignTicket;
  use action closeTicket;
  use action reopenTicket;
}
